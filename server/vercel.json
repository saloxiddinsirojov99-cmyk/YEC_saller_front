{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate --schema=./prisma/schema.prisma",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}